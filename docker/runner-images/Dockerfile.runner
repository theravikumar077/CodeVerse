FROM node:20-slim

# Install build essential and runtimes
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    g++ \
    python3 \
    default-jdk \
    php-cli \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Create a sandbox user for running untrusted user code
RUN useradd -m -u 1001 sandbox

# Set working directory
WORKDIR /workspace

# Set default command
CMD ["sleep", "infinity"]
